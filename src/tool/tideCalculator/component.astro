---
import './style.css';
import type { TideCalculatorUI } from './index';

interface Props {
  ui: TideCalculatorUI;
}

const { ui } = Astro.props;
---

<section id="tide-calculator" class="tide-calculator">
    <div class="main-card">
        <div class="calc-sidebar">
            <div class="sidebar-header">
                <h3>{ui.parametros}</h3>
                <button id="invert-btn" title="Invertir ciclo">
                    <svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M18 18V22H16V18H13L17 14L21 18H18M8 6V2H10V6H13L9 10L5 6H8M3 15V13H5V15H3M3 11V9H5V11H3M3 7V5H5V7H3M19 11V9H21V11H19M19 15V13H21V15H19M19 19V17H21V19H19M3 19V17H5V19H3Z"/></svg>
                </button>
            </div>

            <div class="input-set">
                <div class="input-block">
                    <label>{ui.pleamar}</label>
                    <div class="row">
                        <input type="time" id="high-tide-time" value="12:00" />
                        <div class="unit-input">
                            <input type="number" id="high-tide-height" value="3.5" step="0.1" />
                            <span>m</span>
                        </div>
                    </div>
                </div>

                <div class="input-block">
                    <label>{ui.bajamar}</label>
                    <div class="row">
                        <input type="time" id="low-tide-time" value="06:00" />
                        <div class="unit-input">
                            <input type="number" id="low-tide-height" value="0.5" step="0.1" />
                            <span>m</span>
                        </div>
                    </div>
                </div>

                <div class="input-block featured">
                    <label>{ui.horaConsulta}</label>
                    <input type="time" id="target-time" value="09:00" class="large-time" />
                </div>
            </div>
        </div>

        <div class="calc-content">
            <div class="top-row">
                <div class="result-display">
                    <span class="label">{ui.alturaEstimada}</span>
                    <div class="value-box">
                        <span id="target-value">--</span>
                        <small>{ui.metros}</small>
                    </div>
                    <span id="tide-status" class="status-indicator">--</span>
                </div>
                <div class="summary-info">
                    <div class="stat">
                        <span class="s-label">{ui.amplitud}</span>
                        <span id="amplitude-val">--</span>
                    </div>
                    <div class="stat">
                        <span class="s-label">{ui.duracion}</span>
                        <span id="duration-val">--</span>
                    </div>
                </div>
            </div>

            <div class="chart-area">
                <canvas id="tide-chart"></canvas>
            </div>
        </div>
    </div>

    <div class="table-card">
        <h4>{ui.desglosePorDozavos}</h4>
        <div class="table-wrapper">
            <table id="twelfths-table">
                <thead>
                    <tr>
                        <th>{ui.hora}</th>
                        <th>{ui.estado}</th>
                        <th>%</th>
                        <th>{ui.altura}</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</section>

<script>
    import { Chart, registerables } from 'chart.js';
    import { timeToMins, minsToTime, generateCycle, interpolateHeight } from './logic';
    import type { TideCyclePoint } from './logic';
    Chart.register(...registerables);

    const highTimeEl = document.getElementById('high-tide-time') as HTMLInputElement;
    const highHeightEl = document.getElementById('high-tide-height') as HTMLInputElement;
    const lowTimeEl = document.getElementById('low-tide-time') as HTMLInputElement;
    const lowHeightEl = document.getElementById('low-tide-height') as HTMLInputElement;
    const targetTimeEl = document.getElementById('target-time') as HTMLInputElement;
    const invertBtn = document.getElementById('invert-btn') as HTMLElement;
    const displayValue = document.getElementById('target-value') as HTMLElement;
    const displayStatus = document.getElementById('tide-status') as HTMLElement;
    const displayAmp = document.getElementById('amplitude-val') as HTMLElement;
    const displayDur = document.getElementById('duration-val') as HTMLElement;
    const tableBody = document.querySelector('#twelfths-table tbody') as HTMLElement;
    const inputs = [highTimeEl, highHeightEl, lowTimeEl, lowHeightEl, targetTimeEl];

    let chart: Chart;

    function makeGradient(context: { chart: Chart }): CanvasGradient | undefined {
        const { ctx: c, chartArea } = context.chart;
        if (!chartArea) return undefined;
        const gradient = c.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
        gradient.addColorStop(0, 'rgba(0, 116, 183, 0.2)');
        gradient.addColorStop(1, 'rgba(0, 116, 183, 0)');
        return gradient;
    }

    function buildDatasets() {
        return [
            { data: [], borderColor: '#0074B7', borderWidth: 3, pointRadius: 0, tension: 0.4, fill: true, backgroundColor: makeGradient },
            { data: [], pointRadius: 6, pointBackgroundColor: '#FF6B35', pointBorderColor: 'white', pointBorderWidth: 2, showLine: false },
        ];
    }

    function initChart() {
        const ctx = document.getElementById('tide-chart') as HTMLCanvasElement;
        chart = new Chart(ctx, {
            type: 'line',
            data: { labels: [], datasets: buildDatasets() },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { display: false }, y: { display: true, grid: { color: 'rgba(0,0,0,0.05)' } } },
            },
        });
    }

    function rowLabel(i: number): string {
        if (i === 0) return 'Inicio';
        if (i === 6) return 'Final';
        return '---';
    }

    function updateTable(pts: TideCyclePoint[]) {
        tableBody.innerHTML = pts.map((p, i) => `<tr><td>${minsToTime(p.t)}</td><td>${rowLabel(i)}</td><td>${p.p}</td><td>${p.h.toFixed(2)}m</td></tr>`).join('');
    }

    function updateHeightDisplay(h: number | null, mult: number) {
        if (h !== null) {
            const rising = mult > 0;
            displayValue.textContent = h.toFixed(2);
            displayStatus.textContent = rising ? 'Subiendo' : 'Bajando';
            displayStatus.className = `status-indicator ${rising ? 'up' : 'down'}`;
        } else {
            displayValue.textContent = '--';
            displayStatus.textContent = 'Fuera de rango';
            displayStatus.className = 'status-indicator';
        }
    }

    interface ChartUpdate { pts: TideCyclePoint[]; h: number | null; tT: number; sT: number; dur: number; }

    function updateChartData({ pts, h, tT, sT, dur }: ChartUpdate) {
        const labels = pts.map(p => minsToTime(p.t));
        chart.data.labels = labels;
        chart.data.datasets[0].data = pts.map(p => p.h);
        const rel = tT - sT;
        if (h !== null && rel >= 0 && rel <= dur) {
            chart.data.datasets[1].data = [{ x: labels[Math.round(rel / (dur / 6))], y: h }];
        } else {
            chart.data.datasets[1].data = [];
        }
        chart.update();
    }

    function calculate() {
        const tH = timeToMins(highTimeEl.value);
        const hH = parseFloat(highHeightEl.value);
        const tL = timeToMins(lowTimeEl.value);
        const hL = parseFloat(lowHeightEl.value);
        const tT = timeToMins(targetTimeEl.value);
        if (isNaN(hH) || isNaN(hL)) return;
        const isFlooding = tH > tL;
        const dur = Math.abs(tH - tL);
        const amp = Math.abs(hH - hL);
        const sH = isFlooding ? hL : hH;
        const sT = isFlooding ? tL : tH;
        const mult = isFlooding ? 1 : -1;
        displayAmp.textContent = `${amp.toFixed(2)} m`;
        displayDur.textContent = `${Math.floor(dur / 60)}h ${dur % 60}m`;
        const pts = generateCycle({ sT, dur, amp, sH, mult });
        const h = interpolateHeight({ tT, sT, dur, amp, sH, mult });
        updateHeightDisplay(h, mult);
        updateTable(pts);
        updateChartData(pts, h, tT, sT, dur);
    }

    function invert() {
        const hT = highTimeEl.value;
        const hH = highHeightEl.value;
        highTimeEl.value = lowTimeEl.value;
        highHeightEl.value = lowHeightEl.value;
        lowTimeEl.value = hT;
        lowHeightEl.value = hH;
        calculate();
    }

    inputs.forEach(i => i.addEventListener('input', calculate));
    invertBtn.addEventListener('click', invert);
    initChart();
    calculate();
</script>
