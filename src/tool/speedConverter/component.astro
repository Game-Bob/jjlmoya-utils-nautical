---
import type { SpeedConverterUI } from './index';
interface Props { ui: SpeedConverterUI; }
const { ui } = Astro.props;
const bd = JSON.parse(ui.beaufortDataJson) as { force: number; name: string; sea: string; effect: string; kn: string }[];
---
<section id="speed-converter-root" class="speed-converter" data-ui={JSON.stringify(ui)}>
  <div class="sc-input-grid">
    <div class="sc-input-group">
      <label for="val-kn">{ui.knLabel}</label>
      <div class="sc-input-wrapper"><input type="number" id="val-kn" placeholder="0.0" step="0.1" /></div>
    </div>
    <div class="sc-input-group">
      <label for="val-kmh">{ui.kmhLabel}</label>
      <div class="sc-input-wrapper"><input type="number" id="val-kmh" placeholder="0.0" step="0.1" /></div>
    </div>
    <div class="sc-input-group">
      <label for="val-ms">{ui.msLabel}</label>
      <div class="sc-input-wrapper"><input type="number" id="val-ms" placeholder="0.0" step="0.1" /></div>
    </div>
    <div class="sc-input-group">
      <label for="val-mph">{ui.mphLabel}</label>
      <div class="sc-input-wrapper"><input type="number" id="val-mph" placeholder="0.0" step="0.1" /></div>
    </div>
  </div>
  <div class="sc-beaufort-summary">
    <div class="sc-force-circle" id="f-num">0</div>
    <div class="sc-force-text-box">
      <h2 id="f-desc" class="sc-force-name">{bd[0]?.name ?? ''}</h2>
      <p id="f-effect" class="sc-force-detail">{bd[0]?.effect ?? ''}</p>
    </div>
    <div class="sc-sea-state-box">
      <div class="sc-sea-text">
        <span class="label">{ui.seaStateLabel}</span>
        <p id="f-sea">{bd[0]?.sea ?? ''}</p>
      </div>
    </div>
  </div>
  <div class="sc-table-container">
    <h3>{ui.beaufortTitle}</h3>
    <div class="sc-scroll-area">
      <table class="sc-beaufort-table">
        <thead>
          <tr>
            <th>{ui.forceLabel}</th><th>{ui.descriptionLabel}</th>
            <th>{ui.knotsLabel}</th><th>{ui.effectLabel}</th>
          </tr>
        </thead>
        <tbody>
          {bd.map((b) => (
            <tr data-force={b.force} class="sc-clickable-row">
              <td><span class="sc-force-tag">F{b.force}</span></td>
              <td><strong>{b.name}</strong></td>
              <td>{b.kn}</td>
              <td>{b.sea}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
<script>
  const root = document.getElementById('speed-converter-root') as HTMLElement;
  const ui = JSON.parse(root.dataset.ui as string);
  const bd = JSON.parse(ui.beaufortDataJson) as { force: number; name: string; sea: string; effect: string; kn: string }[];
  const iKn = document.getElementById('val-kn') as HTMLInputElement;
  const iKmh = document.getElementById('val-kmh') as HTMLInputElement;
  const iMs = document.getElementById('val-ms') as HTMLInputElement;
  const iMph = document.getElementById('val-mph') as HTMLInputElement;
  const fNum = document.getElementById('f-num') as HTMLElement;
  const fDesc = document.getElementById('f-desc') as HTMLElement;
  const fEff = document.getElementById('f-effect') as HTMLElement;
  const fSea = document.getElementById('f-sea') as HTMLElement;
  const rows = document.querySelectorAll<HTMLTableRowElement>('.sc-clickable-row');
  const KMH = 1.852, MS = 0.514444, MPH = 1.15078;

  function getForce(kn: number): number {
    const lim = [1,4,7,11,17,22,28,34,41,48,56,64];
    for (let i = 0; i < lim.length; i++) { if (kn < (lim[i] ?? 999)) return i; }
    return 12;
  }

  function renderBeaufort(kn: number) {
    const f = getForce(kn);
    const d = bd[f];
    if (!d) return;
    fNum.textContent = String(f);
    fDesc.textContent = d.name;
    fEff.textContent = d.effect;
    fSea.textContent = d.sea;
    rows.forEach((r) => r.classList.toggle('active', parseInt(r.dataset.force ?? '-1') === f));
  }

  function sync(skip: string, kn: number) {
    if (skip !== 'val-kn') iKn.value = kn.toFixed(1);
    if (skip !== 'val-kmh') iKmh.value = (kn * KMH).toFixed(1);
    if (skip !== 'val-ms') iMs.value = (kn * MS).toFixed(2);
    if (skip !== 'val-mph') iMph.value = (kn * MPH).toFixed(2);
    renderBeaufort(kn);
    localStorage.setItem('jjlmoya-nautical-speed', String(kn));
  }

  iKn.addEventListener('input', (e) => sync('val-kn', parseFloat((e.target as HTMLInputElement).value)||0));
  iKmh.addEventListener('input', (e) => sync('val-kmh', (parseFloat((e.target as HTMLInputElement).value)||0)/KMH));
  iMs.addEventListener('input', (e) => sync('val-ms', (parseFloat((e.target as HTMLInputElement).value)||0)/MS));
  iMph.addEventListener('input', (e) => sync('val-mph', (parseFloat((e.target as HTMLInputElement).value)||0)/MPH));

  rows.forEach((row) => {
    row.addEventListener('click', () => {
      const f = parseInt(row.dataset.force ?? '0');
      const d = bd[f];
      let kn = 0;
      if (f === 12) { kn = 65; }
      else if (f > 0) { kn = parseFloat(d?.kn.split('-')[0] ?? '0') || 0; }
      iKn.value = String(kn);
      sync('val-kn', kn);
    });
  });

  const savedKn = parseFloat(localStorage.getItem('jjlmoya-nautical-speed') ?? '0') || 0;
  iKn.value = savedKn > 0 ? String(savedKn) : '';
  sync('val-kn', savedKn);
</script>

<style>
  .speed-converter {
    --n-bg: #fff;
    --n-bg-muted: #f1f5f9;
    --n-text: #0f172a;
    --n-text-muted: #475569;
    --n-text-dim: #64748b;
    --n-border: #e2e8f0;
    --n-shadow: rgba(0, 0, 0, 0.05);
    --n-primary: #3b82f6;
    --n-primary-on: #fff;
    --n-accent: #6366f1;
    --n-cyan: #0891b2;
    --n-success: #10b981;
    --n-warning: #f59e0b;
    --n-error: #f43f5e;

    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  :global(.theme-dark) .speed-converter {
    --n-bg: #0f172a;
    --n-bg-muted: #1e293b;
    --n-text: #f8fafc;
    --n-text-muted: #94a3b8;
    --n-text-dim: #64748b;
    --n-border: #334155;
    --n-shadow: rgba(0, 0, 0, 0.3);
    --n-primary: #60a5fa;
    --n-primary-on: #fff;
    --n-accent: #818cf8;
    --n-cyan: #22d3ee;
    --n-success: #34d399;
    --n-warning: #fbbf24;
    --n-error: #fb7185;
  }

  .sc-input-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    background: var(--n-bg);
    border: 1px solid var(--n-border);
    border-radius: 1.5rem;
    padding: 2rem;
  }

  .sc-input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sc-input-group label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--n-text-muted);
    text-transform: uppercase;
  }

  .sc-input-wrapper {
    background: var(--n-bg-muted);
    border: 2px solid var(--n-border);
    border-radius: 0.8rem;
    padding: 0.8rem 1rem;
    transition: border-color 0.2s;
  }

  .sc-input-wrapper:focus-within {
    border-color: var(--n-cyan);
  }

  .sc-input-wrapper input {
    background: transparent;
    border: none;
    outline: none;
    color: var(--n-text);
    font-size: 1.5rem;
    font-weight: 800;
    width: 100%;
  }

  .sc-input-wrapper input::-webkit-outer-spin-button,
  .sc-input-wrapper input::-webkit-inner-spin-button {
    appearance: none;
  }

  .sc-beaufort-summary {
    background: var(--n-primary);
    color: var(--n-primary-on);
    border-radius: 1.5rem;
    padding: 2rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem 2rem;
    align-items: center;
  }

  .sc-force-circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--n-primary-on);
    flex-shrink: 0;
  }

  .sc-force-text-box {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .sc-force-name {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--n-primary-on);
  }

  .sc-force-detail {
    margin: 0;
    opacity: 0.8;
    font-size: 0.9rem;
    color: var(--n-primary-on);
  }

  .sc-sea-state-box {
    grid-column: 1 / -1;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    padding: 1rem 1.5rem;
  }

  .sc-sea-text .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    opacity: 0.7;
    color: var(--n-primary-on);
    font-weight: 700;
  }

  .sc-sea-text p {
    margin: 0.2rem 0 0;
    font-weight: 600;
    color: var(--n-primary-on);
  }

  .sc-table-container {
    background: var(--n-bg);
    border: 1px solid var(--n-border);
    border-radius: 1.5rem;
    overflow: hidden;
  }

  .sc-table-container h3 {
    padding: 1.5rem;
    margin: 0;
    font-size: 1rem;
    color: var(--n-text-muted);
    border-bottom: 1px solid var(--n-border);
    font-weight: 700;
  }

  .sc-scroll-area {
    overflow-x: auto;
  }

  .sc-beaufort-table {
    width: 100%;
    border-collapse: collapse;
  }

  .sc-beaufort-table th {
    text-align: left;
    padding: 0.8rem 1rem;
    font-size: 0.75rem;
    color: var(--n-text-muted);
    text-transform: uppercase;
    border-bottom: 2px solid var(--n-border);
  }

  .sc-beaufort-table td {
    padding: 0.8rem 1rem;
    font-size: 0.9rem;
    color: var(--n-text-muted);
    border-bottom: 1px solid var(--n-border);
  }

  .sc-clickable-row {
    cursor: pointer;
    transition: background 0.15s;
  }

  .sc-clickable-row:hover {
    background: var(--n-bg-muted);
  }

  .sc-clickable-row.active {
    background: var(--n-primary);
  }

  .sc-clickable-row.active td {
    color: var(--n-primary-on);
  }

  .sc-force-tag {
    background: var(--n-bg-muted);
    padding: 0.2rem 0.5rem;
    border-radius: 0.4rem;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--n-text);
  }

  .sc-clickable-row.active .sc-force-tag {
    background: rgba(255, 255, 255, 0.2);
    color: var(--n-primary-on);
  }

  @media (max-width: 640px) {
    .sc-beaufort-summary {
      grid-template-columns: 1fr;
    }

    .sc-force-circle {
      width: 60px;
      height: 60px;
      font-size: 2rem;
    }
  }
</style>
