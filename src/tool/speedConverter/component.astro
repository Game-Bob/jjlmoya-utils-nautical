---
import './style.css';
import type { SpeedConverterUI } from './index';

interface Props {
  ui: SpeedConverterUI;
}

const { ui } = Astro.props;
---

<section id="speed-converter" class="speed-converter">
  <div class="input-card">
    <div class="input-group">
      <div class="field">
        <label class="field-label">{ui.labelKnots}</label>
        <input type="number" id="input-knots" value="10" step="0.1" min="0" />
      </div>
      <div class="or-divider">
        <span>OR</span>
      </div>
      <div class="field">
        <label class="field-label">{ui.labelBeaufort}</label>
        <select id="input-beaufort">
          {Array.from({ length: 13 }, (_, i) => (
            <option value={i}>BF {i}</option>
          ))}
        </select>
      </div>
    </div>
    <div class="btn-row">
      <button id="convert-btn" class="btn-primary">{ui.btnConvert}</button>
      <button id="reset-btn" class="btn-secondary">{ui.btnReset}</button>
    </div>
  </div>

  <div class="results-grid">
    <div class="result-tile">
      <span class="tile-label">{ui.labelKnots}</span>
      <span id="res-knots" class="tile-value">10.00</span>
    </div>
    <div class="result-tile">
      <span class="tile-label">{ui.labelKmh}</span>
      <span id="res-kmh" class="tile-value">--</span>
    </div>
    <div class="result-tile">
      <span class="tile-label">{ui.labelMph}</span>
      <span id="res-mph" class="tile-value">--</span>
    </div>
    <div class="result-tile">
      <span class="tile-label">{ui.labelMs}</span>
      <span id="res-ms" class="tile-value">--</span>
    </div>
    <div class="result-tile beaufort-tile">
      <span class="tile-label">{ui.labelBeaufort}</span>
      <span id="res-beaufort" class="tile-value tile-bf">--</span>
    </div>
  </div>

  <div class="table-card">
    <h4 class="table-title">{ui.tableTitle}</h4>
    <div class="table-wrapper">
      <table class="beaufort-ref-table">
        <thead>
          <tr>
            <th>{ui.tableForce}</th>
            <th>{ui.tableKnots}</th>
            <th>{ui.tableDesc}</th>
            <th>{ui.tableSeaState}</th>
          </tr>
        </thead>
        <tbody id="beaufort-ref-body"></tbody>
      </table>
    </div>
  </div>
</section>

<script>
  import { convertAllSpeeds, beaufortToKnots, BEAUFORT_DATA } from './logic';

  const inputKnots = document.getElementById('input-knots') as HTMLInputElement;
  const inputBf = document.getElementById('input-beaufort') as HTMLSelectElement;
  const resKnots = document.getElementById('res-knots') as HTMLElement;
  const resKmh = document.getElementById('res-kmh') as HTMLElement;
  const resMph = document.getElementById('res-mph') as HTMLElement;
  const resMs = document.getElementById('res-ms') as HTMLElement;
  const resBf = document.getElementById('res-beaufort') as HTMLElement;
  const refBody = document.getElementById('beaufort-ref-body') as HTMLElement;

  function convert(knots: number) {
    const r = convertAllSpeeds(knots);
    resKnots.textContent = r.knots.toFixed(2);
    resKmh.textContent = r.kmh.toFixed(2);
    resMph.textContent = r.mph.toFixed(2);
    resMs.textContent = r.ms.toFixed(2);
    resBf.textContent = String(r.beaufort);
    refBody.querySelectorAll('tr').forEach(tr => {
      tr.classList.toggle('active-row', parseInt(tr.dataset.bf || '-1') === r.beaufort);
    });
  }

  function renderTable() {
    refBody.innerHTML = BEAUFORT_DATA.map(entry => `
      <tr data-bf="${entry.force}">
        <td>${entry.force}</td>
        <td>${entry.minKnots}–${entry.maxKnots === 999 ? '63+' : entry.maxKnots}</td>
        <td>${entry.description}</td>
        <td>${entry.seaState}</td>
      </tr>
    `).join('');
  }

  inputKnots.addEventListener('input', () => {
    const v = parseFloat(inputKnots.value);
    if (!isNaN(v)) convert(v);
  });

  inputBf.addEventListener('change', () => {
    const knots = beaufortToKnots(parseInt(inputBf.value));
    inputKnots.value = String(knots);
    convert(knots);
  });

  document.getElementById('convert-btn')?.addEventListener('click', () => {
    const v = parseFloat(inputKnots.value);
    if (!isNaN(v)) convert(v);
  });

  document.getElementById('reset-btn')?.addEventListener('click', () => {
    inputKnots.value = '10';
    inputBf.value = '0';
    convert(10);
  });

  renderTable();
  convert(10);
</script>
