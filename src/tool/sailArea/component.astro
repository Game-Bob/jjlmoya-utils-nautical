---
import './style.css';
import type { SailAreaUI } from './index';

interface Props {
  ui: SailAreaUI;
}

const { ui } = Astro.props;
---

<section id="sail-area" class="sail-area">
  <div class="sail-card">
    <div class="sail-sidebar">
      <div class="field">
        <label class="field-label">{ui.sailType}</label>
        <select id="sail-type">
          <option value="triangle">{ui.typTriangle}</option>
          <option value="quad">{ui.typQuad}</option>
          <option value="genoa">{ui.typGenoa}</option>
        </select>
      </div>

      <div id="inputs-triangle" class="input-group">
        <div class="field">
          <label class="field-label">{ui.labelBase} (m)</label>
          <input type="number" id="tri-base" value="8" step="0.1" min="0" />
        </div>
        <div class="field">
          <label class="field-label">{ui.labelHeight} (m)</label>
          <input type="number" id="tri-height" value="12" step="0.1" min="0" />
        </div>
      </div>

      <div id="inputs-quad" class="input-group hidden">
        <div class="field">
          <label class="field-label">{ui.labelBase} (m)</label>
          <input type="number" id="quad-base" value="8" step="0.1" min="0" />
        </div>
        <div class="field">
          <label class="field-label">{ui.labelHeight} (m)</label>
          <input type="number" id="quad-height" value="12" step="0.1" min="0" />
        </div>
        <div class="field">
          <label class="field-label">Clew (m)</label>
          <input type="number" id="quad-clew" value="4" step="0.1" min="0" />
        </div>
      </div>

      <div id="inputs-genoa" class="input-group hidden">
        <div class="field">
          <label class="field-label">{ui.labelJ} (m)</label>
          <input type="number" id="gen-J" value="5" step="0.1" min="0" />
        </div>
        <div class="field">
          <label class="field-label">{ui.labelI} (m)</label>
          <input type="number" id="gen-I" value="15" step="0.1" min="0" />
        </div>
        <div class="field">
          <label class="field-label">{ui.labelLP} (m)</label>
          <input type="number" id="gen-LP" value="7" step="0.1" min="0" />
        </div>
      </div>

      <div class="field">
        <label class="field-label">{ui.labelDisplacement} (kg)</label>
        <input type="number" id="displacement" value="5000" step="100" min="0" />
      </div>

      <div class="btn-row">
        <button id="calculate-btn" class="btn-primary">{ui.btnCalculate}</button>
        <button id="reset-btn" class="btn-secondary">{ui.btnReset}</button>
      </div>
    </div>

    <div class="sail-results">
      <div class="result-block">
        <span class="result-label">{ui.resultArea}</span>
        <div class="result-value-box">
          <span id="result-area">--</span>
          <small>m²</small>
        </div>
      </div>
      <div class="result-block">
        <span class="result-label">{ui.resultRatio}</span>
        <div class="result-value-box">
          <span id="result-ratio">--</span>
          <small>SA/D</small>
        </div>
      </div>
      <div id="sail-diagram" class="sail-diagram">
        <svg id="sail-svg" viewBox="0 0 200 250" width="200" height="250"></svg>
      </div>
    </div>
  </div>
</section>

<script>
  import { triangleSailArea, quadSailArea, genoaArea, sailAreaRatio } from './logic';

  const typeEl = document.getElementById('sail-type') as HTMLSelectElement;
  const displEl = document.getElementById('displacement') as HTMLInputElement;
  const areaEl = document.getElementById('result-area') as HTMLElement;
  const ratioEl = document.getElementById('result-ratio') as HTMLElement;
  const sailSvg = document.getElementById('sail-svg') as unknown as SVGSVGElement;

  const groups: Record<string, HTMLElement | null> = {
    triangle: document.getElementById('inputs-triangle'),
    quad: document.getElementById('inputs-quad'),
    genoa: document.getElementById('inputs-genoa'),
  };

  function showGroup(type: string) {
    Object.entries(groups).forEach(([key, el]) => {
      if (el) el.classList.toggle('hidden', key !== type);
    });
  }

  function drawTriangle(area: number) {
    sailSvg.innerHTML = `<polygon points="100,20 20,230 180,230" fill="var(--color-sail-fill,rgba(0,116,183,0.15))" stroke="var(--color-primary,#0074B7)" stroke-width="2"/><text x="100" y="140" text-anchor="middle" font-size="14" fill="var(--color-text-base,#334155)">${area.toFixed(1)} m²</text>`;
  }

  function drawQuad(area: number) {
    sailSvg.innerHTML = `<polygon points="40,20 160,20 180,230 20,230" fill="var(--color-sail-fill,rgba(0,116,183,0.15))" stroke="var(--color-primary,#0074B7)" stroke-width="2"/><text x="100" y="135" text-anchor="middle" font-size="14" fill="var(--color-text-base,#334155)">${area.toFixed(1)} m²</text>`;
  }

  function drawGenoa(area: number) {
    sailSvg.innerHTML = `<polygon points="100,20 20,230 160,230" fill="var(--color-sail-fill,rgba(0,116,183,0.15))" stroke="var(--color-primary,#0074B7)" stroke-width="2"/><line x1="100" y1="20" x2="100" y2="230" stroke="var(--color-border,#e2e8f0)" stroke-dasharray="4"/><text x="100" y="140" text-anchor="middle" font-size="14" fill="var(--color-text-base,#334155)">${area.toFixed(1)} m²</text>`;
  }

  function getNum(id: string): number {
    return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
  }

  function calcTriangle(): number {
    const area = triangleSailArea(getNum('tri-base'), getNum('tri-height'));
    drawTriangle(area);
    return area;
  }

  function calcQuad(): number {
    const area = quadSailArea(getNum('quad-base'), getNum('quad-height'), getNum('quad-clew'));
    drawQuad(area);
    return area;
  }

  function calcGenoa(): number {
    const area = genoaArea(getNum('gen-J'), getNum('gen-I'), getNum('gen-LP'));
    drawGenoa(area);
    return area;
  }

  function calculate() {
    const type = typeEl.value;
    let area = 0;
    if (type === 'triangle') area = calcTriangle();
    else if (type === 'quad') area = calcQuad();
    else area = calcGenoa();
    const ratio = sailAreaRatio(area, parseFloat(displEl.value) || 0);
    areaEl.textContent = area.toFixed(2);
    ratioEl.textContent = ratio.toFixed(3);
  }

  function reset() {
    (document.getElementById('tri-base') as HTMLInputElement).value = '8';
    (document.getElementById('tri-height') as HTMLInputElement).value = '12';
    (document.getElementById('quad-base') as HTMLInputElement).value = '8';
    (document.getElementById('quad-height') as HTMLInputElement).value = '12';
    (document.getElementById('quad-clew') as HTMLInputElement).value = '4';
    (document.getElementById('gen-J') as HTMLInputElement).value = '5';
    (document.getElementById('gen-I') as HTMLInputElement).value = '15';
    (document.getElementById('gen-LP') as HTMLInputElement).value = '7';
    displEl.value = '5000';
    typeEl.value = 'triangle';
    showGroup('triangle');
    calculate();
  }

  typeEl.addEventListener('change', () => { showGroup(typeEl.value); calculate(); });
  document.getElementById('calculate-btn')?.addEventListener('click', calculate);
  document.getElementById('reset-btn')?.addEventListener('click', reset);
  document.querySelectorAll('input[type="number"]').forEach(el => el.addEventListener('input', calculate));

  showGroup('triangle');
  calculate();
</script>
